# Files Claude Code shouldn't crawl when scanning the repo.
# Keep this list tight — every entry trades discoverability for context budget.

# Vendor + build artifacts
node_modules/
.next/
.vercel/
.git/
coverage/
*.tsbuildinfo

# Lockfile — huge, low signal
package-lock.json

# SQL bundles — open by file path when needed (not via crawl)
supabase/RESET_SESIZARI.sql
supabase/schema.sql
supabase/migrations/*.sql

# Local data dumps / scratch
*.log
.DS_Store
