{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/stiri/fetch",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/intreruperi/refresh",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/newsletter/digest",
      "schedule": "0 8 * * 1"
    }
  ],
  "functions": {
    "src/app/api/ai/chat/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/ai/classify/route.ts": {
      "maxDuration": 15
    },
    "src/app/api/ai/improve/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/upload/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/stiri/fetch/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/intreruperi/refresh/route.ts": {
      "maxDuration": 60
    },
    "src/app/api/newsletter/digest/route.ts": {
      "maxDuration": 60
    }
  }
}
