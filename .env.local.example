# ============================================
# Civia — Environment Variables
# ============================================
# 1. Copy this file: cp .env.local.example .env.local
# 2. Fill in real values from Supabase Dashboard + Groq Console
# 3. NEVER commit .env.local (it's in .gitignore)

# --- Supabase (get from https://supabase.com/dashboard/project/_/settings/api) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...   # "anon public" key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...        # "service_role" secret — SERVER ONLY

# --- Groq AI (get from https://console.groq.com/keys) ---
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile           # main model for formal text + chat
GROQ_MODEL_FAST=llama-3.1-8b-instant         # for fast classification

# --- App config ---
# ⚠️ MUST be set to https://civia.ro in production — the next.config.ts guard
# will throw a build error if localhost leaks into a CI/Vercel build.
NEXT_PUBLIC_SITE_URL=https://civia.ro

# --- Cron / admin triggers ---
# Bearer secret used by Vercel Cron to trigger /api/stiri/fetch
CRON_SECRET=change-me-to-a-long-random-string

# --- Optional: Analytics (Plausible) ---
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=civia.ro
# NEXT_PUBLIC_PLAUSIBLE_API=https://plausible.io/api/event

# --- Upstash Redis (rate limiting) ---
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# --- Error Tracking (Sentry) ---
NEXT_PUBLIC_SENTRY_DSN=https://xxx@o123.ingest.sentry.io/456

# --- Email (Resend) — for notifications ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Civia <onboarding@resend.dev>

# ============================================
# OAuth providers (Google, Apple)
# ============================================
# Set these to "1" ONLY AFTER you've configured the provider in
# Supabase Dashboard. If set before configuration, users will see
# the buttons but get "provider not enabled" errors when clicking.
# NEXT_PUBLIC_ENABLE_GOOGLE_AUTH=1
# NEXT_PUBLIC_ENABLE_APPLE_AUTH=1
#
# OAuth is configured in the Supabase Dashboard, NOT via env vars here:
#   Supabase Dashboard → Authentication → Providers → Google / Apple
#   - Create OAuth client in Google Cloud Console / Apple Developer Portal
#   - Add redirect URL: https://<your-project>.supabase.co/auth/v1/callback
#   - Paste Client ID + Secret into Supabase Dashboard
#   - In Supabase → Authentication → URL Configuration:
#       Site URL: https://civia.ro
#       Redirect URLs: https://civia.ro/auth/callback,
#                      http://localhost:3000/auth/callback
